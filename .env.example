# Database
# Direct PostgreSQL connection URL (used by Prisma migrations)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Prisma Accelerate connection URL (used at runtime with connection pooling)
PRISMA_DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=your_api_key_here"

# Auth (NextAuth v5)
# Generate with: npx auth secret
AUTH_SECRET="your_auth_secret_here"
AUTH_URL="http://localhost:3000"

# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers
AUTH_GITHUB_ID="your_github_oauth_client_id"
AUTH_GITHUB_SECRET="your_github_oauth_client_secret"

# GitHub Personal Access Token (used for GitHub Models / AI inference)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN="your_github_personal_access_token"
